# Copy to deploy/.env and fill in before running docker compose.
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://govcrawler:change-me@db:5432/govcrawler
JWT_SECRET=generate-with-python-c-import-secrets-print-secrets-token-urlsafe-48
CREDENTIAL_ENC_KEY=generate-with-python-c-from-cryptography.fernet-import-Fernet-print-Fernet.generate_key().decode()

# The hostname agents and browsers use to reach the portal.
# Public deployment:   DOMAIN=app.yourorg.com  (Caddy gets a Let's Encrypt cert)
# LAN / internal:      DOMAIN=govcrawler.internal  (pair with TLS_MODE=internal below)
# Plain HTTP (no TLS): DOMAIN=:80               (pair with TLS_MODE=off)
#
# Localhost / Docker-on-your-machine:
#   DOMAIN=:80 and TLS_MODE=off  →  http://localhost in the browser.
#   The docker-compose.override.yml also exposes api on 127.0.0.1:18001 and
#   db on 127.0.0.1:5433 for direct access (curl, psql, DBeaver, etc.).
#   For prod: docker compose -f docker-compose.yml up -d  (skips the override).
DOMAIN=your-server.example.com

# TLS mode for the Caddy reverse proxy (see deploy/Caddyfile for details):
#   acme     — Let's Encrypt auto-provisioning (default).
#              Requires a public DNS A record + ports 80/443 open to the internet.
#   internal — Caddy issues certs from its own CA. No internet needed.
#              Install the CA on org machines once:
#                docker compose exec proxy caddy trust
#              Ideal for org-internal LAN servers.
#   off      — Disable TLS entirely. Set DOMAIN=:80. TLS must be handled
#              upstream (org load balancer, VPN gateway, nginx).
TLS_MODE=acme

# Least-privilege runtime role (Alembic 0020) — GOVCRAWLER_APP_PASSWORD is only
# read by the `migrate` service, which creates/updates the role; DATABASE_URL_APP
# is what api/dispatcher actually connect with at runtime. Same host/db as
# DATABASE_URL above, different user/password. See deploy/SECURITY.md.
GOVCRAWLER_APP_PASSWORD=change-me-too
DATABASE_URL_APP=postgresql://govcrawler_app:change-me-too@db:5432/govcrawler

# Optional, only set during a JWT_SECRET / CREDENTIAL_ENC_KEY rotation —
# see deploy/SECURITY.md's rotation procedure. Leave unset otherwise.
JWT_SECRET_PREV=
CREDENTIAL_ENC_KEY_PREV=

# Optional — override the public URL ADMIN_ORIGIN / OAUTH_REDIRECT_BASE_URL.
# Defaults to https://${DOMAIN}.  Only set these if your external URL differs
# from DOMAIN (e.g. behind a port-forwarding NAT or with a path prefix).
ADMIN_ORIGIN=
OAUTH_REDIRECT_BASE_URL=

# Required before a Microsoft/Google SMTP credential can be connected — one-time
# Azure AD / Google Cloud app registration. See .docs/outreach.md and
# .docs/configuration.md. OAUTH_REDIRECT_BASE_URL defaults to https://${DOMAIN}.
OAUTH_MS_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
